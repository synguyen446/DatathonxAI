{
  "manifest_version": 3,
  "name": "Truth Lens",
  "version": "1.0",
  "description": "Detects whether an image is real or AI-generated using a local FastAPI backend.",

  "permissions": [
    "contextMenus",
    "activeTab",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "http://localhost:8001/*",
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "Truth Lens"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
